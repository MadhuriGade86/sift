# Copy this file to .env and fill in real values. Never commit .env itself.

# Neon Postgres connection string (use the -pooler variant)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Frontend URL — used for CORS and for building links in emails
APP_URL=http://localhost:5173

# Resend API key for transactional email (signup verification, password reset, invites)
# Leave blank in local dev — emails will log to the console instead of sending.
RESEND_API_KEY=

# The "from" address for outgoing emails (must be a domain verified in Resend for production)
EMAIL_FROM=Sift <onboarding@resend.dev>

NODE_ENV=development
